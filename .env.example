# Copy to .env and fill secrets. Do NOT commit .env with real keys.

DB_URL=jdbc:postgresql://localhost:5432/strange_safety
DB_USERNAME=postgres
DB_PASSWORD=change-me
JWT_SECRET=local-development-jwt-secret-change-before-shared-use-32bytes
AES_SECRET_KEY=StrangeSafetyKey
AES_IV=StrangeSafetyIv!

MQTT_HOST=localhost
MQTT_PORT=1883

# --- Gemini / VLM (see docs/GEMINI_ENV_SETUP.md) ---
GEMINI_API_KEY=your-gemini-api-key-here

VLM_MOCK_MODE=false
VLM_FORCE_MOCK=false

VLM_SNAPSHOT_ASSIST_ENABLED=true
VLM_SNAPSHOT_ASSIST_MOCK_ANALYZE=false

# Same token on AI edge + back internal APIs
AI_SERVICE_TOKEN=change-me-long-random-service-token

# strange_ai internal_vlm_api (default port 8091)
AI_VLM_WORKER_BASE_URL=http://localhost:8091
AI_VLM_WORKER_TIMEOUT_SECONDS=180

# Semantic search query embedding in Spring (optional; AI worker can embed instead)
VLM_EMBEDDING_PROVIDER=gemini
GEMINI_VLM_MODEL=gemini-2.0-flash
VLM_QUERY_EMBEDDING_MODEL=text-embedding-004